{
  "env": {
    "browser": true,
    "es2021": true,
    "serviceworker": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_"
      }
    ],
    "no-console": "warn",
    "no-debugger": "error",
    "no-duplicate-imports": "error",
    "prefer-const": "warn",
    "eqeqeq": [
      "warn",
      "always",
      {
        "null": "ignore"
      }
    ],
    "curly": [
      "warn",
      "multi-line"
    ],
    "no-var": "warn"
  },
  "globals": {
    "Chart": "readonly",
    "process": "readonly"
  }
}